# ============================================
# Production Environment Variables Template
# ============================================
# Copy this file to .env.production and fill in your values.
# .env.production is gitignored (contains secrets).
#
# Usage:
#   cp .env.production.example .env.production
#   # Then edit .env.production with real values
# ============================================

# Django Settings
# Generate a strong secret key: https://djecrety.ir/
SECRET_KEY=your-production-secret-key-here
DEBUG=False

# ALLOWED_HOSTS: Comma-separated list of host/domain names
# 'backend-prod' is required for Docker inter-container communication
# Add your EC2 public IP, DuckDNS domain, and www subdomain after deployment
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend-prod,your-domain.com,www.your-domain.com,your-ec2-ip

# Database Configuration (matches docker-compose.prod.yml)
DB_NAME=tdd_backend_django_prod_db
DB_USER=produser
DB_PASS=your-db-password
DB_HOST=your-rds-endpoint.ap-south-2.rds.amazonaws.com
DB_PORT=3306

# Frontend URL for email verification/password reset links
# Use your deployed frontend domain in production
FRONTEND_BASE_URL=https://your-domain.duckdns.org

# Email Configuration (Gmail SMTP)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# CORS Configuration (frontend URLs allowed to access the API)
# Format: comma-separated origins
CORS_ALLOWED_ORIGINS=https://your-domain.duckdns.org,http://your-ec2-ip

# Feature Flags (Game Section)
GAME_SECTION_ENABLED=true
GAME_LEADERBOARD_ENABLED=true

# Feature Flags (Report Download)
# Set to 'false' to disable report download
ENABLE_REPORT_DOWNLOAD=true